# Copy to .env for docker compose:  cp .env.docker.example .env

# API port on your machine (Splunk uses 8000 — keep AgentGuard on 8001)
API_PORT=8001

# PostgreSQL (used by docker compose db service)
POSTGRES_USER=agentguard
POSTGRES_PASSWORD=agentguard
POSTGRES_DB=agentguard

# Django
DJANGO_SECRET_KEY=change-me-for-shared-deployments
DEBUG=1

# Optional API key for ingest (leave empty for open ingest in dev)
# Or create a hashed key: docker compose run --rm api shell create_sdk_key
AGENTGUARD_API_KEY=

# Splunk — default mock mode works without Splunk installed
SPLUNK_MOCK=1

# If Splunk runs on your HOST machine (not in Docker), uncomment and set:
# SPLUNK_MOCK=0
# SPLUNK_HEC_URL=https://host.docker.internal:8088
# SPLUNK_HEC_TOKEN=your-hec-token
# SPLUNK_HOST=https://host.docker.internal:8089
# SPLUNK_REST_TOKEN=your-splunk-session-key
# SPLUNK_VERIFY_SSL=0

# Celery — 1 = sync in API process; 0 + profile async = worker service
CELERY_TASK_ALWAYS_EAGER=1
ASYNC_SPAN_INGEST=0
# For async pipeline: ASYNC_SPAN_INGEST=1 CELERY_TASK_ALWAYS_EAGER=0
#   docker compose --profile async up --build -d
