# Splunk HEC (primary telemetry sink)
SPLUNK_HEC_URL=https://localhost:8088
SPLUNK_HEC_TOKEN=your-hec-token-here

# Splunk REST for MCP queries (SPLUNK_MOCK=0 for live Splunk)
SPLUNK_MOCK=1
SPLUNK_HOST=https://localhost:8089
SPLUNK_REST_TOKEN=
SPLUNK_TOKEN=
SPLUNK_INDEX=main
SPLUNK_VERIFY_SSL=0

# Splunk AI Assistant (optional — falls back to rule-based NL→SPL)
SPLUNK_AI_ASSISTANT_ENABLED=0
SPLUNK_AI_ASSISTANT_URL=

# MLTK model name (when Splunk_ML_Toolkit is installed)
AGENTGUARD_MLTK_MODEL=agentguard_latency_density

# Django backend mirror + alert webhook target
AGENTGUARD_BACKEND_URL=http://localhost:8001
AGENTGUARD_API_KEY=
AGENTGUARD_ALERT_PORT=8765

# OpenAI (legacy PromptOps eval only)
OPENAI_API_KEY=
