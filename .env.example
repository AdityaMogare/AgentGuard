# Splunk HEC (primary telemetry sink)
SPLUNK_HEC_URL=https://localhost:8088
SPLUNK_HEC_TOKEN=your-hec-token-here

# Optional Splunk REST for MCP (SPLUNK_MOCK=0 uses real Splunk + Django fallback)
SPLUNK_MOCK=1
SPLUNK_HOST=https://localhost:8089
SPLUNK_REST_TOKEN=
SPLUNK_VERIFY_SSL=0

# Django backend mirror (optional)
AGENTGUARD_BACKEND_URL=http://localhost:8000
AGENTGUARD_API_KEY=

# OpenAI (legacy PromptOps eval only)
OPENAI_API_KEY=
